{
  "name": "@tracebench/adapter-claude-code",
  "version": "0.2.3",
  "description": "Tracebench adapter for Claude Code session logs (~/.claude/projects/**/*.jsonl).",
  "license": "Apache-2.0",
  "author": "Skandesh",
  "homepage": "https://github.com/Skandesh/tracebench",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Skandesh/tracebench.git",
    "directory": "packages/adapter-claude-code"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "@tracebench/core": "workspace:*"
  }
}
