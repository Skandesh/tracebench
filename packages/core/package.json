{
  "name": "@tracebench/core",
  "version": "0.2.5",
  "description": "Canonical event schema, SQLite storage, and pricing for tracebench adapters.",
  "license": "Apache-2.0",
  "author": "Skandesh",
  "homepage": "https://github.com/Skandesh/tracebench",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Skandesh/tracebench.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "import": "./dist/schema.js"
    },
    "./db": {
      "types": "./dist/db.d.ts",
      "import": "./dist/db.js"
    },
    "./pricing": {
      "types": "./dist/pricing.d.ts",
      "import": "./dist/pricing.js"
    },
    "./query": {
      "types": "./dist/query.d.ts",
      "import": "./dist/query.js"
    }
  },
  "files": [
    "dist",
    "pricing.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "better-sqlite3": "^11.1.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11"
  }
}
