{
  "name": "tracebench",
  "version": "0.2.3",
  "type": "module",
  "description": "Local-first viewer for AI coding agent sessions. Reads Claude Code, Codex, and Cursor.",
  "keywords": [
    "claude-code",
    "codex",
    "agents",
    "ai",
    "viewer",
    "local-first",
    "tokens",
    "cost"
  ],
  "license": "Apache-2.0",
  "author": "Skandesh",
  "homepage": "https://github.com/Skandesh/tracebench",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Skandesh/tracebench.git"
  },
  "bugs": "https://github.com/Skandesh/tracebench/issues",
  "main": "./dist/server.js",
  "bin": {
    "tracebench": "./dist/cli.js"
  },
  "files": [
    "dist",
    "ui",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepack": "node scripts/prepack.mjs"
  },
  "dependencies": {
    "@tracebench/core": "workspace:*",
    "@tracebench/adapter-claude-code": "workspace:*",
    "@tracebench/adapter-codex": "workspace:*",
    "@tracebench/adapter-cursor": "workspace:*",
    "fastify": "^5.0.0",
    "@fastify/static": "^8.0.0"
  },
  "devDependencies": {
    "tsx": "^4.16.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  }
}
